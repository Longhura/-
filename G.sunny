local interactDD

local function GetInteractOpts()
    local o = {}
    for i, e in ipairs(S.ScannedInteract) do
        local lock = IsAllowed(e.id) and "[MO]" or "[KHOA]"
        local short = e.name
        if #short > 25 then short = short:sub(1,22).."..." end
        table.insert(o, ("%d. %s %s [%s] %dst"):format(i, lock, short, e.kind, e.distance))
        if i >= 50 then break end
    end
    if #o == 0 then table.insert(o, "(trống)") end
    return o
end

local function RefreshInteract()
    ScanInteractables()
    local txt = ""
    for i, e in ipairs(S.ScannedInteract) do
        local lock = IsAllowed(e.id) and "[MO] " or "[KHOA] "
        txt = txt .. ("%s%d. [%s] %s (%dst)\n"):format(lock, i, e.kind, e.name, e.distance)
        if i >= 12 then txt = txt .. ("... +%d khác"):format(#S.ScannedInteract - 12); break end
    end
    if txt == "" then txt = "Không có vật nào gần đây" end
    interactPara:Set({Title=("Tổng: %d"):format(#S.ScannedInteract), Content=txt})
    if interactDD then interactDD:Refresh(GetInteractOpts()) end
end

Tab3:CreateButton({Name="Quét lại danh sách", Callback=RefreshInteract})

interactDD = Tab3:CreateDropdown({
    Name = "Chọn vật để xem/khóa",
    Options = GetInteractOpts(),
    CurrentOption = {}, MultipleOptions = false, Flag = "InterSel",
    Callback = function(o)
        local c = type(o)=="table" and o[1] or o
        if type(c)=="string" then
            local i = tonumber(c:match("^(%d+)%."))
            if i and S.ScannedInteract[i] then
                S.SelectedInteract = i
                local info = GetObjectInfo(S.ScannedInteract[i].inst)
                infoPara:Set({Title="Chi tiết: "..S.ScannedInteract[i].name,
                    Content=FormatObjectInfo(info)})
            end
        end
    end,
})

