Tab5:CreateSection("Nhân bản vật phẩm")
Tab5:CreateButton({Name="Nhân bản LOCAL → _SUNNY_REPLICA", Callback=function()
    local it = S.BagItems[S.SelectedBag]; if not it then return end
    local c, e = Cloner.LocalClone(it.inst, EnsureReplica())
    Rayfield:Notify({Title=c and "Đã clone" or "Lỗi",
        Content=c and it.name or e, Duration=2})
end})

Tab5:CreateButton({Name="Nhân bản → Backpack (client-side)", Callback=function()
    local it = S.BagItems[S.SelectedBag]; if not it then return end
    local c, e = Cloner.LocalClone(it.inst, LP:FindFirstChild("Backpack"))
    Rayfield:Notify({Title=c and "Đã clone" or "Lỗi",
        Content=c and (it.name.." → Backpack") or e, Duration=2})
end})

Tab5:CreateButton({Name="Nhân bản THẬT (Replay Spy remote)", Callback=function()
    local ok, msg = Cloner.ReplayPickup(S.ReplayCount, S.ReplayDelay)
    Rayfield:Notify({Title=ok and "Đang phát lại" or "Cần setup Spy",
        Content=msg, Duration=4})
end})

Tab5:CreateButton({Name="Nhân bản TOOL ĐANG CẦM", Callback=function()
    local ch = LP.Character
    local t = ch and ch:FindFirstChildOfClass("Tool")
    if not t then
        Rayfield:Notify({Title="Lỗi", Content="Không cầm tool", Duration=2}); return
    end
    local c, e = Cloner.LocalClone(t, EnsureReplica())
    Rayfield:Notify({Title=c and "Đã clone" or "Lỗi",
        Content=c and ("Tool: "..t.Name) or e, Duration=2})
end})

Tab5:CreateButton({Name="Equip vật phẩm đang chọn", Callback=function()
    local it = S.BagItems[S.SelectedBag]; if not it then return end
    local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
    if hum then pcall(function() hum:EquipTool(it.inst) end) end
end})

Tab5:CreateButton({Name="Dọn _SUNNY_REPLICA", Callback=function()
    local f = Workspace:FindFirstChild("_SUNNY_REPLICA")
    if f then f:ClearAllChildren() end
end})

------------------------------------------------------------------
-- TAB 6: KHO ĐỒ
------------------------------------------------------------------
local Tab6 = Window:CreateTab("Kho đồ", "package")

local stPara = Tab6:CreateParagraph({Title="Kho: 0", Content="Nhấn Quét"})
local stInfoPara = Tab6:CreateParagraph({Title="Chi tiết item kho", Content=""})
local stDD

local function GetStOpts()
    local o = {}
    for i, it in ipairs(S.StorageItems) do
        local short = it.name
        if #short > 25 then short = short:sub(1,22).."..." end
        table.insert(o, ("%d. %s"):format(i, short))
        if i >= 100 then break end
    end
    if #o == 0 then table.insert(o, "(trống)") end
    return o
end

local function RefreshSt()
    task.spawn(function()
        ScanStorageItems()
        local txt = ""
        for i, it in ipairs(S.StorageItems) do
            txt = txt .. ("%d. %s\n"):format(i, it.name)
            if i >= 22 then txt = txt .. ("... +%d"):format(#S.StorageItems - 22); break end
        end
        if txt == "" then txt = "Không tìm thấy item" end
        stPara:Set({Title=("Kho: %d"):format(#S.StorageItems), Content=txt})
        if stDD then stDD:Refresh(GetStOpts()) end
    end)
end

stDD = Tab6:CreateDropdown({
    Name = "Chọn item kho", Options = GetStOpts(),
    CurrentOption = {}, MultipleOptions = false, Flag = "StSel",
    Callback = function(o)
        local c = type(o)=="table" and o[1] or o
        if type(c)=="string" then
            local i = tonumber(c:match("^(%d+)%."))
            if i and S.StorageItems[i] then
                S.SelectedStorage = i
                local info = GetObjectInfo(S.StorageItems[i].inst)
                stInfoPara:Set({Title="Chi tiết: "..S.StorageItems[i].name,
                    Content=FormatObjectInfo(info)})
            end
        end
    end,
})

Tab6:CreateButton({Name="Quét kho đồ", Callback=RefreshSt})

Tab6:CreateButton({Name="Nhân bản → _SUNNY_REPLICA", Callback=function()
    local it = S.StorageItems[S.SelectedStorage]; if not it then return end
    local c, e = Cloner.LocalClone(it.inst, EnsureReplica())
    Rayfield:Notify({Title=c and "Đã clone" or "Lỗi", Content=c and it.name or e, Duration=2})
end})

Tab6:CreateButton({Name="Nhân bản → Backpack (chỉ Tool)", Callback=function()
    local it = S.StorageItems[S.SelectedStorage]; if not it then return end
    if not (it.inst:IsA("Tool") or it.inst:IsA("HopperBin")) then
        Rayfield:Notify({Title="Lỗi", Content="Chỉ Tool", Duration=2}); return
    end
    local c, e = Cloner.LocalClone(it.inst, LP:FindFirstChild("Backpack"))
    Rayfield:Notify({Title=c and "Đã clone" or "Lỗi",
        Content=c and (it.name.." → Backpack") or e, Duration=2})
end})

Tab6:CreateInput({
    Name = "Thêm đường dẫn kho mới",
    PlaceholderText = "VD: ReplicatedStorage.Pets",
    RemoveTextAfterFocusLost = true, Flag = "PathAdd",
    Callback = function(t)
        if t == "" then return end
        for _, p in ipairs(S.StoragePaths) do if p == t then return end end
        table.insert(S.StoragePaths, t)
        Rayfield:Notify({Title="Đã thêm", Content=t, Duration=2})
    end,
})

------------------------------------------------------------------
-- TAB 7: KÉO VẬT PHẨM (PHYSICS)
------------------------------------------------------------------
local Tab7 = Window:CreateTab("Kéo đồ", "move")

Tab7:CreateDropdown({
    Name = "Vị trí object theo player",
    Options = {"Sau lưng", "Trước mặt", "Trên đầu", "Theo hướng nhìn", "Xoay vòng quanh"},
    CurrentOption = {"Sau lưng"},
    MultipleOptions = false, Flag = "DragMode",
    Callback = function(o)
        local c = type(o)=="table" and o[1] or o
        if c == "Sau lưng" then S.DragMode = "Back"
        elseif c == "Trước mặt" then S.DragMode = "Front"
        elseif c == "Trên đầu" then S.DragMode = "Top"
        elseif c == "Theo hướng nhìn" then S.DragMode = "Crosshair"
        elseif c == "Xoay vòng quanh" then S.DragMode = "Orbit" end
    end,
})

Tab7:CreateSlider({Name = "Khoảng cách (offset)",
    Range = {1, 30}, Increment = 1, Suffix = " studs",
    CurrentValue = 5, Flag = "DragDist",
    Callback = function(v) S.DragDistance = v end,
})

Tab7:CreateSlider({Name = "Tốc độ xoay (chế độ Orbit)",
    Range = {1, 10}, Increment = 1, Suffix = "x",
    CurrentValue = 2, Flag = "OrbSpd",
    Callback = function(v) S.OrbitSpeed = v end,
})

Tab7:CreateSection("Điều khiển")
Tab7:CreateButton({Name="GRAB vật gần nhất", Callback=function()
    local ok, err = Drag.GrabNearest()
    Rayfield:Notify({Title=ok and "Đã grab" or "Thất bại",
        Content=ok and (S.DragTarget and S.DragTarget.Name or "?") or err, Duration=2})
end})

Tab7:CreateButton({Name="GRAB Handle của tool đang cầm", Callback=function()
    local ch = LP.Character
    local t = ch and ch:FindFirstChildOfClass("Tool")
    local handle = t and t:FindFirstChild("Handle")
    if not handle then
        Rayfield:Notify({Title="Lỗi", Content="Không cầm tool có Handle", Duration=2}); return
    end
    Drag.AttachTo(handle)
end})

Tab7:CreateButton({Name="THẢ vật phẩm", Callback=function()
    Drag.Release()
end})

Tab7:CreateToggle({
    Name = "Tự động kéo (auto re-grab gần nhất)",
    CurrentValue = false, Flag = "AutoDrag",
    Callback = function(v)
        S.AutoDragEnabled = v
        if v then StartAutoDrag() end
    end,
})

------------------------------------------------------------------
-- TAB 8: REMOTE SPY
------------------------------------------------------------------
local Tab8 = Window:CreateTab("Spy Remote", "radio")

Tab8:CreateToggle({Name="BẬT Spy theo dõi remote", CurrentValue=false, Flag="Spy",
    Callback=function(v)
        S.SpyEnabled = v
        if v then
            local ok = InstallSpy()
            Rayfield:Notify({Title=ok and "Spy bật" or "Không hỗ trợ",
                Content=ok and "Hãy nhặt 1 item trong game"
                            or "Executor thiếu hookmetamethod",
                Duration=4})
        end
    end})

local spyPara = Tab8:CreateParagraph({Title="Log: 0", Content="(trống)"})

task.spawn(function()
    while task.wait(0.8) do
        if S.SpyEnabled then
            pcall(function()
                local txt = ""
                for i, e in ipairs(S.LastSpyLog) do
                    txt = txt .. ("[%s] %s:%s\n"):format(e.time, e.name, e.method)
                    if i >= 12 then break end
                end
                if txt == "" then txt = "(chưa có)" end
                spyPara:Set({Title=("Log: %d"):format(#S.LastSpyLog), Content=txt})
            end)
        end
    end
end)

Tab8:CreateButton({Name="CAPTURE remote mới nhất", Callback=function()
    if #S.LastSpyLog == 0 then
        Rayfield:Notify({Title="Trống", Content="Hãy nhặt item rồi capture", Duration=3}); return
    end
    local l = S.LastSpyLog[1]
    S.CapturedPickupRemote = {instance=l.remote, method=l.method, args=l.args}
    Rayfield:Notify({Title="Đã capture", Content="Remote: "..l.name, Duration=3})
end})

Tab8:CreateSlider({Name="Số lần phát lại", Range={1,100}, Increment=1,
    Suffix=" lần", CurrentValue=1, Flag="ReplayN",
    Callback=function(v) S.ReplayCount = v end})

Tab8:CreateSlider({Name="Delay phát lại (min 0.05s an toàn)",
    Range={0.05, 2}, Increment=0.05, Suffix="s",
    CurrentValue=0.05, Flag="ReplayD",
    Callback=function(v) S.ReplayDelay = v end})

Tab8:CreateButton({Name="Xóa log", Callback=function() S.LastSpyLog = {} end})

Tab8:CreateLabel("Lưu ý: delay <0.05s có thể bị kick 'Remote Spam'")

