Tab9:CreateButton({Name="Thu nhỏ menu → FAB", Callback=function()
    pcall(function() Rayfield:Toggle() end)
    ShowFAB()
end})

Tab9:CreateButton({Name="DỪNG TẤT CẢ", Callback=function()
    S.MasterEnabled = false
    S.HUDMasterEnabled = false
    S.AutoDragEnabled = false
    S.ShowSphere = false
    S.SpyEnabled = false
    Sphere.Destroy()
    Drag.Release()
    Rayfield:Notify({Title="Đã dừng", Content="Tất cả tính năng đã tắt", Duration=2})
end})

Tab9:CreateLabel("Mobile: chạm FAB tròn 'S' để mở/đóng menu")
Tab9:CreateLabel("Desktop: phím K để toggle nhanh")
Tab9:CreateLabel("Tác giả: SUNNY HUB Team | v5.0")

--==================================================================--
-- [PHẦN 11] FAB (FLOATING ACTION BUTTON)                            --
--==================================================================--
function ShowFAB()
    if _G.SUNNY.FAB then _G.SUNNY.FAB:Destroy() end

    local parent = PlayerGui
    pcall(function()
        local probe = Instance.new("ScreenGui")
        probe.Parent = CoreGui; probe:Destroy()
        parent = CoreGui
    end)

    local gui = Instance.new("ScreenGui")
    gui.Name = "_SUNNY_FAB"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = parent
    _G.SUNNY.FAB = gui

    local sz = IsMobile and 75 or 60

    local fab = Instance.new("Frame")
    fab.Size = UDim2.new(0, sz, 0, sz)
    fab.Position = UDim2.new(0, 20, 0.4, 0)
    fab.BackgroundColor3 = Color3.fromRGB(15, 12, 25)
    fab.BorderSizePixel = 0
    fab.Active = true
    fab.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0); corner.Parent = fab

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 90, 200)
    stroke.Thickness = 2.5; stroke.Transparency = 0.1
    stroke.Parent = fab

    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 25, 75)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(25, 18, 40)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 8, 20)),
    })
    grad.Rotation = 135; grad.Parent = fab

    local logo = Instance.new("TextLabel")
    logo.Size = UDim2.new(1, 0, 1, 0)
    logo.BackgroundTransparency = 1
    logo.Text = "S"
    logo.TextColor3 = Color3.fromRGB(255, 110, 220)
    logo.TextScaled = true
    logo.Font = Enum.Font.GothamBlack
    logo.Parent = fab

    local pad = Instance.new("UIPadding")
    pad.PaddingTop = UDim.new(0, sz * 0.15)
    pad.PaddingBottom = UDim.new(0, sz * 0.15)
    pad.PaddingLeft = UDim.new(0, sz * 0.25)
    pad.PaddingRight = UDim.new(0, sz * 0.25)
    pad.Parent = logo

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 14, 0, 14)
    dot.Position = UDim2.new(1, -16, 0, 2)
    dot.BackgroundColor3 = Color3.fromRGB(50, 220, 80)
    dot.BorderSizePixel = 0
    dot.Visible = false
    dot.Parent = fab
    local dc = Instance.new("UICorner"); dc.CornerRadius = UDim.new(1,0); dc.Parent = dot

    task.spawn(function()
        while gui.Parent do
            dot.Visible = S.MasterEnabled or S.HUDMasterEnabled or S.AutoDragEnabled
            if S.MasterEnabled then
                TweenService:Create(stroke, TweenInfo.new(0.6), {
                    Transparency=0.5, Thickness=3.5}):Play()
                task.wait(0.6)
                TweenService:Create(stroke, TweenInfo.new(0.6), {
                    Transparency=0.1, Thickness=2.5}):Play()
                task.wait(0.6)
            else task.wait(0.3) end
        end
    end)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
    btn.Text = ""; btn.AutoButtonColor = false; btn.Parent = fab

    local dragging, dragStart, startPos, hasDragged = false, nil, nil, false
    local THRESH = IsMobile and 10 or 5

    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; hasDragged = false
            dragStart = input.Position; startPos = fab.Position
        end
    end)

    local moveConn
    moveConn = UserInputService.InputChanged:Connect(function(input)
        if not gui.Parent then moveConn:Disconnect(); return end
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement
           and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local d = input.Position - dragStart
        if math.abs(d.X) > THRESH or math.abs(d.Y) > THRESH then hasDragged = true end
        if hasDragged then
            local cam = workspace.CurrentCamera
            local vp = cam and cam.ViewportSize or Vector2.new(1920, 1080)
            local nx = math.clamp(startPos.X.Offset + d.X, 0, vp.X - sz)
            local ny = math.clamp(startPos.Y.Offset + d.Y, 0, vp.Y - sz)
            fab.Position = UDim2.new(0, nx, 0, ny)
        end
    end)
    table.insert(_G.SUNNY.Connections, moveConn)

    local endConn
    endConn = UserInputService.InputEnded:Connect(function(input)
        if not gui.Parent then endConn:Disconnect(); return end
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    table.insert(_G.SUNNY.Connections, endConn)

    btn.MouseButton1Click:Connect(function()
        if hasDragged then return end
        TweenService:Create(fab, TweenInfo.new(0.08), {
            Size = UDim2.new(0, sz-6, 0, sz-6)}):Play()
        task.wait(0.08)
        TweenService:Create(fab, TweenInfo.new(0.12, Enum.EasingStyle.Back), {
            Size = UDim2.new(0, sz, 0, sz)}):Play()
        task.wait(0.12)
        gui:Destroy()
        _G.SUNNY.FAB = nil
        pcall(function() Rayfield:Toggle() end)
    end)
end

--==================================================================--
-- [PHẦN 12] KEYBIND + LIFECYCLE                                     --
--==================================================================--
local kbConn = UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.K then
        pcall(function() Rayfield:Toggle() end)
    end
end)
table.insert(_G.SUNNY.Connections, kbConn)

-- FIX RESPAWN: re-attach drag target sau khi character spawn lại
local charConn = LP.CharacterAdded:Connect(function(newChar)
    S._cooldown = {}
    task.wait(2)  -- Đợi character + backpack load đầy đủ

    pcall(RefreshBag)
    if S.ShowSphere then Sphere.Create() end

    -- Nếu user vẫn còn drag target → tự re-grab
    if S.DragTarget and S.DragTarget.Parent then
        local oldTarget = S.DragTarget
        Drag.Release()
        task.wait(0.5)
        Drag.AttachTo(oldTarget)
    end
end)
table.insert(_G.SUNNY.Connections, charConn)

--==================================================================--
-- [PHẦN 13] KHỞI ĐỘNG                                               --
--==================================================================--
pcall(function() Rayfield:LoadConfiguration() end)

task.spawn(function()
    task.wait(0.5)
    pcall(RefreshBag)
    pcall(RefreshSt)
    pcall(RefreshInteract)
end)

_G.SUNNY.Loaded = true

Rayfield:Notify({
    Title = "SUNNY HUB V5 đã sẵn sàng",
    Content = IsMobile
        and "Mobile mode - menu thuần Việt, dễ dùng"
        or "Desktop mode - nhấn K để toggle menu",
    Duration = 5,
})

Rayfield:Notify({
    Title = "Hướng dẫn nhân bản THẬT",
    Content = "Tab 'Spy Remote' → bật Spy → nhặt 1 item → Capture → Tab Túi đồ → Nhân bản THẬT",
    Duration = 8,
})

