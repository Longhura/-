        if type(c)=="string" then
            local i = tonumber(c:match("^(%d+)%."))
            if i and S.HUDList[i] then
                S.SelectedHUD = i
                local info = GetObjectInfo(S.HUDList[i].inst)
                hudInfoPara:Set({
