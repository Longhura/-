-- Đảm bảo load lại không bị duplicate UI hoặc thread chết treo
_G.SUNNY = _G.SUNNY or {}
if _G.SUNNY.Loaded then
    pcall(function()
        -- Dừng tất cả thread cũ qua flag
        if _G.SUNNY.State then
            _G.SUNNY.State.MasterEnabled = false
            _G.SUNNY.State.HUDMasterEnabled = false
            _G.SUNNY.State.AutoDragEnabled = false
            _G.SUNNY.State.ShowSphere = false
            _G.SUNNY.State.SpyEnabled = false
        end
        if _G.SUNNY.Rayfield then _G.SUNNY.Rayfield:Destroy() end
        if _G.SUNNY.FAB then _G.SUNNY.FAB:Destroy() end
        if _G.SUNNY.SpherePart then _G.SUNNY.SpherePart:Destroy() end
        if _G.SUNNY.DragAlign then _G.SUNNY.DragAlign:Destroy() end
        if _G.SUNNY.DragAlignOri then _G.SUNNY.DragAlignOri:Destroy() end
        if _G.SUNNY.DragHRPAtt then _G.SUNNY.DragHRPAtt:Destroy() end
        if _G.SUNNY.DragPartAtt then _G.SUNNY.DragPartAtt:Destroy() end
        for _, conn in pairs(_G.SUNNY.Connections or {}) do
            pcall(function() conn:Disconnect() end)
        end
    end)
    _G.SUNNY = {}
    task.wait(0.5)
end

_G.SUNNY.Connections = {}

