------------------------------------------------------------------
local Tab6 = Window:CreateTab("Kho đồ", "package")

local stPara = Tab6:CreateParagraph({Title="Kho: 0", Content="Nhấn Quét"})
local stInfoPara = Tab6:CreateParagraph({
    Title = "Chi tiết item kho",
    Content = "Chọn từ dropdown"
})

local stDD

local function GetStOpts()
    local o = {}
    for i, it in ipairs(S.StorageItems) do
        local short = it.name
        if #short > 25 then short = short:sub(1,22).."..." end
        table.insert(o, ("%d. %s"):format(i, short))
        if i >= 100 then break end
    end
    if #o == 0 then table.insert(o, "(trống)") end
    return o
end

local function RefreshSt()
    task.spawn(function()
        ScanStorageItems()
        local txt = ""
        for i, it in ipairs(S.StorageItems) do
            txt = txt .. ("%d. %s\n"):format(i, it.name)
            if i >= 22 then
                txt = txt .. ("... +%d"):format(#S.StorageItems - 22); break
            end
        end
        if txt == "" then txt = "Không tìm thấy item nào" end
        stPara:Set({Title=("Kho: %d"):format(#S.StorageItems), Content=txt})
        if stDD then stDD:Refresh(GetStOpts()) end
    end)
end

stDD = Tab6:CreateDropdown({
    Name = "Chọn item kho", Options = GetStOpts(),
    CurrentOption = {}, MultipleOptions = false, Flag = "StSel",
    Callback = function(o)
        local c = type(o)=="table" and o[1] or o
        if type(c)=="string" then
            local i = tonumber(c:match("^(%d+)%."))
            if i and S.StorageItems[i] then
                S.SelectedStorage = i
                local info = GetObjectInfo(S.StorageItems[i].inst)
                stInfoPara:Set({
                    Title = "Chi tiết: " .. S.StorageItems[i].name,
                    Content = FormatObjectInfo(info),
                })
            end
        end
    end,
})

Tab6:CreateButton({Name="Quét kho đồ", Callback=RefreshSt})

Tab6:CreateButton({Name="Nhân bản → _SUNNY_STORAGE", Callback=function()
    local it = S.StorageItems[S.SelectedStorage]; if not it then return end
    local c, e = Cloner.LocalClone(it.inst, EnsureStorage())
    Rayfield:Notify({Title=c and "Đã clone" or "Lỗi", Content=c and it.name or e, Duration=2})
end})

Tab6:CreateButton({Name="Nhân bản → Backpack (chỉ Tool)", Callback=function()
    local it = S.StorageItems[S.SelectedStorage]; if not it then return end
    if not (it.inst:IsA("Tool") or it.inst:IsA("HopperBin")) then
        Rayfield:Notify({Title="Lỗi", Content="Chỉ áp dụng cho Tool", Duration=2})
        return
    end
    local c, e = Cloner.LocalClone(it.inst, LP:FindFirstChild("Backpack"))
    Rayfield:Notify({Title=c and "Đã clone" or "Lỗi", Content=c and (it.name.." → Backpack") or e, Duration=2})
end})

Tab6:CreateInput({
    Name = "Thêm đường dẫn kho mới",
    PlaceholderText = "VD: ReplicatedStorage.Pets",
    RemoveTextAfterFocusLost = true, Flag = "PathAdd",
    Callback = function(t)
        if t == "" then return end
        for _, p in ipairs(S.StoragePaths) do if p == t then return end end
        table.insert(S.StoragePaths, t)
        Rayfield:Notify({Title="Đã thêm path", Content=t, Duration=2})
    end,
})

------------------------------------------------------------------
-- TAB 7: KÉO VẬT PHẨM (NÂNG CẤP)
------------------------------------------------------------------
local Tab7 = Window:CreateTab("Kéo đồ", "move")

Tab7:CreateSection("Kéo/Theo vật phẩm xung quanh")

Tab7:CreateDropdown({
    Name = "Vị trí object theo player",
    Options = {"Sau lưng", "Trước mặt", "Trên đầu", "Bên phải", "Theo hướng nhìn"},
    CurrentOption = {"Sau lưng"},
    MultipleOptions = false, Flag = "DragMode",
    Callback = function(o)
        local c = type(o)=="table" and o[1] or o
        if c == "Sau lưng" then S.DragMode = "Back"
        elseif c == "Trước mặt" then S.DragMode = "Front"
        elseif c == "Trên đầu" then S.DragMode = "Top"
        elseif c == "Bên phải" then S.DragMode = "Right"
        elseif c == "Theo hướng nhìn" then S.DragMode = "Crosshair" end
    end,
})

Tab7:CreateSlider({
    Name = "Khoảng cách (offset)",
    Range = {1, 30}, Increment = 1, Suffix = " studs",
    CurrentValue = 5, Flag = "DragDist",
    Callback = function(v) S.DragDistance = v end,
})

Tab7:CreateSection("Điều khiển")

Tab7:CreateButton({Name="GRAB vật gần nhất", Callback=function()
    local ok, err = Drag.GrabNearest()
    Rayfield:Notify({
        Title = ok and "Đã grab" or "Thất bại",
        Content = ok and ("Đang theo: "..(S.DragTarget and S.DragTarget.Name or "?")) or err,
        Duration = 2,
    })
end})

Tab7:CreateButton({Name="GRAB Handle của tool đang cầm", Callback=function()
    local ch = LP.Character
    local t = ch and ch:FindFirstChildOfClass("Tool")
    local handle = t and t:FindFirstChild("Handle")
    if not handle then
        Rayfield:Notify({Title="Lỗi", Content="Không cầm tool có Handle", Duration=2})
        return
    end
    Drag.AttachTo(handle)
    Rayfield:Notify({Title="Đã grab", Content=t.Name, Duration=2})
end})

Tab7:CreateButton({Name="THẢ vật phẩm", Callback=function()
    Drag.Release()
    Rayfield:Notify({Title="Đã thả", Content="Đã release object", Duration=2})
end})

Tab7:CreateSection("TỰ ĐỘNG kéo")

Tab7:CreateToggle({
    Name = "Tự động kéo vật gần nhất (auto re-grab)",
    CurrentValue = false, Flag = "AutoDrag",
    Callback = function(v)
        S.AutoDragEnabled = v
        if v then
            StartAutoDrag()
            Rayfield:Notify({
                Title = "Auto Drag bật",
                Content = "Sẽ tự grab vật khi rỗng tay",
                Duration = 3,
            })
        end
    end,
})

Tab7:CreateLabel("Mẹo: bật cùng Bán kính lớn để hút nhiều vật")
Tab7:CreateLabel("Auto Drag sẽ tự re-grab sau khi respawn")

------------------------------------------------------------------
-- TAB 8: REMOTE SPY (nhân bản remote pickup)
------------------------------------------------------------------
local Tab8 = Window:CreateTab("Spy Remote", "radio")

Tab8:CreateSection("Theo dõi remote để nhân bản pickup")

Tab8:CreateToggle({
    Name = "BẬT Spy theo dõi remote",
    CurrentValue = false, Flag = "Spy",
    Callback = function(v)
        S.SpyEnabled = v
        if v then
            local ok = InstallSpy()
            Rayfield:Notify({
                Title = ok and "Spy bật" or "Không hỗ trợ",
                Content = ok and "Hãy thực hiện hành động nhặt 1 item trong game"
                              or "Executor thiếu hookmetamethod",
                Duration = 4,
            })
        end
    end,
})

local spyPara = Tab8:CreateParagraph({Title="Log: 0", Content="(trống)"})

task.spawn(function()
    while task.wait(0.8) do
        if S.SpyEnabled then
            pcall(function()
                local txt = ""
                for i, e in ipairs(S.LastSpyLog) do
                    txt = txt .. ("[%s] %s:%s\n"):format(e.time, e.name, e.method)
                    if i >= 12 then break end
                end
                if txt == "" then txt = "(chưa có remote nào)" end
                spyPara:Set({Title=("Log: %d"):format(#S.LastSpyLog), Content=txt})
            end)
        end
    end
end)

Tab8:CreateButton({
    Name = "CAPTURE remote mới nhất (làm template clone)",
    Callback = function()
        if #S.LastSpyLog == 0 then
            Rayfield:Notify({Title="Trống", Content="Hãy nhặt item rồi mới capture", Duration=3})
            return
        end
        local l = S.LastSpyLog[1]
        S.CapturedPickupRemote = {instance=l.remote, method=l.method, args=l.args}
        Rayfield:Notify({
            Title = "Đã capture",
            Content = "Remote: "..l.name.." | Vào Tab Túi → Nhân bản THẬT",
            Duration = 4,
        })
    end,
})

Tab8:CreateSlider({Name="Số lần phát lại", Range={1,100}, Increment=1,
    Suffix=" lần", CurrentValue=1, Flag="ReplayN",
    Callback=function() end})

Tab8:CreateButton({Name="Xóa log", Callback=function() S.LastSpyLog = {} end})

Tab8:CreateLabel("Cách dùng: 1) Bật Spy 2) Nhặt 1 item")
Tab8:CreateLabel("3) Nhấn Capture 4) Tab Túi → Nhân bản THẬT")

