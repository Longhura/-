--==================================================================--
-- [PHẦN 4] HÀM TIỆN ÍCH                                             --
--==================================================================--
local function GetHRP()
    local c = LP.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function DistanceTo(t)
    local hrp = GetHRP()
    if not hrp or not t then return math.huge end
    local p
    if typeof(t) == "Vector3" then p = t
    elseif t:IsA("BasePart") then p = t.Position
    elseif t:IsA("Attachment") then p = t.WorldPosition
    elseif t:IsA("Model") then
        local pp = t.PrimaryPart or t:FindFirstChildWhichIsA("BasePart")
        if pp then p = pp.Position else return math.huge end
    else return math.huge end
    return (hrp.Position - p).Magnitude
end

local function Cooldown(inst, dur)
    local now = tick()
    if (S._cooldown[inst] or 0) + dur > now then return false end
    S._cooldown[inst] = now
    return true
end

-- ID duy nhất ổn định cho instance (kể cả khi 2 object cùng tên)
-- Kết hợp FullName + DebugId để đảm bảo unique tuyệt đối
local function GetUniqueID(inst)
    if not inst or not inst.Parent then return tostring(inst) end
    local fullname = ""
    pcall(function() fullname = inst:GetFullName() end)
    -- DebugId là ID nội bộ Roblox - unique 100% per instance
    local dbgId = ""
    pcall(function() dbgId = tostring(inst:GetDebugId()) end)
    return fullname .. "#" .. dbgId
end

-- Lấy thông tin chi tiết object để hiển thị
local function GetObjectInfo(inst)
    if not inst then return "(nil)" end
    local info = {}
    info.class = inst.ClassName
    info.name = inst.Name
    pcall(function() info.fullname = inst:GetFullName() end)
    pcall(function() info.debugId = tostring(inst:GetDebugId()) end)

    -- Attributes (game-specific data)
    info.attributes = {}
    pcall(function()
        for k, v in pairs(inst:GetAttributes()) do
            info.attributes[k] = tostring(v)
        end
    end)

    -- Children quan trọng (Configuration, IntValue, StringValue...)
    info.values = {}
    for _, c in ipairs(inst:GetChildren()) do
        if c:IsA("IntValue") or c:IsA("StringValue") or c:IsA("NumberValue")
            or c:IsA("BoolValue") or c:IsA("ObjectValue") then
            pcall(function()
                info.values[c.Name] = tostring(c.Value)
            end)
        end
    end

    -- Position nếu có
    if inst:IsA("BasePart") then
        info.position = inst.Position
    elseif inst:IsA("Model") then
        local pp = inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart")
        if pp then info.position = pp.Position end
    end

    return info
end

-- Format object info thành string đẹp cho UI
local function FormatObjectInfo(info)
    if type(info) ~= "table" then return tostring(info) end
    local lines = {}
    table.insert(lines, "Class: " .. info.class)
    table.insert(lines, "Tên: " .. info.name)
    if info.fullname and #info.fullname < 80 then
        table.insert(lines, "Path: " .. info.fullname)
    elseif info.fullname then
        table.insert(lines, "Path: ..." .. info.fullname:sub(-77))
    end
    if info.debugId and info.debugId ~= "" then
        table.insert(lines, "ID: " .. info.debugId:sub(1, 12))
    end
    if info.position then
        table.insert(lines, ("Pos: %d,%d,%d"):format(
            info.position.X, info.position.Y, info.position.Z
        ))
    end

    -- Attributes
    local attrCount = 0
    for _ in pairs(info.attributes) do attrCount = attrCount + 1 end
    if attrCount > 0 then
        table.insert(lines, "--- Attributes ---")
        for k, v in pairs(info.attributes) do
            if #v > 30 then v = v:sub(1, 27) .. "..." end
            table.insert(lines, k .. " = " .. v)
        end
    end

    -- Values
    local valCount = 0
    for _ in pairs(info.values) do valCount = valCount + 1 end
    if valCount > 0 then
        table.insert(lines, "--- Values ---")
        for k, v in pairs(info.values) do
            if #v > 30 then v = v:sub(1, 27) .. "..." end
            table.insert(lines, k .. " = " .. v)
        end
    end

    return table.concat(lines, "\n")
end

--==================================================================--
-- [PHẦN 5] HÌNH CẦU NEON HIỂN THỊ PHẠM VI                           --
--==================================================================--
local Sphere = {}

function Sphere.Create()
    Sphere.Destroy()
    local p = Instance.new("Part")
    p.Name = "_SUNNY_Sphere"
    p.Shape = Enum.PartType.Ball
    p.Material = Enum.Material.ForceField
    p.Color = Color3.fromRGB(255, 90, 200)
    p.Transparency = 0.7
    p.CanCollide, p.CanQuery, p.CanTouch = false, false, false
    p.Anchored, p.Massless = true, true
    local d = S.Radius * 2
    p.Size = Vector3.new(d, d, d)
    p.Parent = Workspace

    local sel = Instance.new("SelectionSphere")
    sel.Adornee = p
    sel.Color3 = Color3.fromRGB(0, 255, 255)
    sel.SurfaceColor3 = Color3.fromRGB(255, 90, 200)
    sel.SurfaceTransparency = 0.85
    sel.Transparency = 0.3
    sel.Parent = p

    _G.SUNNY.SpherePart = p

    -- Follow nhân vật bằng RenderStepped
    task.spawn(function()
        while S.ShowSphere and _G.SUNNY.SpherePart do
            local hrp = GetHRP()
            if hrp then _G.SUNNY.SpherePart.CFrame = CFrame.new(hrp.Position) end
            RunService.RenderStepped:Wait()
        end
    end)
end

function Sphere.UpdateSize()
    if _G.SUNNY.SpherePart then
        local d = S.Radius * 2
        TweenService:Create(_G.SUNNY.SpherePart, TweenInfo.new(0.2), {
            Size = Vector3.new(d, d, d)
        }):Play()
    end
end

function Sphere.Destroy()
    if _G.SUNNY.SpherePart then
        _G.SUNNY.SpherePart:Destroy()
        _G.SUNNY.SpherePart = nil
    end
end

--==================================================================--
-- [PHẦN 6] ENGINE 4 LỚP TƯƠNG TÁC                                   --
--==================================================================--
local function IsAllowed(id)
    local v = S.InteractWhitelist[id]
    if v == nil then return true end
    return v == true
end

local function FireUIClick(x, y)
    pcall(function()
        if IsMobile then
            VIM:SendTouchEvent(1, 1, x, y)
            task.wait()
            VIM:SendTouchEvent(1, 3, x, y)
        else
            VIM:SendMouseButtonEvent(x, y, 0, true, game, 1)
            task.wait()
            VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
        end
    end)
end

local function IsTrulyVisible(obj)
    if not obj.Visible then return false end
    if obj.AbsoluteSize.X <= 0 or obj.AbsoluteSize.Y <= 0 then return false end
    local p = obj.Parent
    while p and p ~= PlayerGui do
        if p:IsA("ScreenGui") and not p.Enabled then return false end
        if p:IsA("GuiObject") and not p.Visible then return false end
        p = p.Parent
    end
    return true
end

local function IsLikelyTouch(p)
    if not p:IsA("BasePart") or not p.CanTouch then return false end
    local m = p:FindFirstAncestorOfClass("Model")
    if m and m:FindFirstChildOfClass("Humanoid") then return false end
    local n = p.Name:lower()
    for _, k in ipairs({"button","xp","crate","coin","gem","orb","pad","trigger","touch","pickup","reward","drop","loot"}) do
        if n:find(k, 1, true) then return true end
    end
    if p:FindFirstChildOfClass("TouchTransmitter") then return true end
    return false
end

-- LOOP 4 LỚP
local function ScanAll()
    -- Lớp 1: UI Buttons
    if S.EnableUIClick then
        for _, sg in ipairs(PlayerGui:GetChildren()) do
            if sg:IsA("ScreenGui") and sg.Enabled
                and sg.Name ~= "_SUNNY_FAB" and sg.Name ~= "Rayfield" then
                pcall(function()
                    for _, d in ipairs(sg:GetDescendants()) do
                        if (d:IsA("TextButton") or d:IsA("ImageButton")) and IsTrulyVisible(d) then
                            local id = GetUniqueID(d)
                            if IsAllowed(id) and Cooldown(d, 0.1) then
                                local pos, sz = d.AbsolutePosition, d.AbsoluteSize
                                local cx, cy = pos.X + sz.X/2, pos.Y + sz.Y/2
                                if cx > 0 and cy > 0 then FireUIClick(cx, cy) end
                            end
                        end
                    end
                end)
            end
        end
    end

    -- Lớp 2,3,4: World interactions (1 lần descendants)
    if S.EnableProximity or S.EnableClickDetector or S.EnableTouch then
        local hrp = GetHRP()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if not S.MasterEnabled then return end

            -- ProximityPrompt
            if S.EnableProximity and obj:IsA("ProximityPrompt") and obj.Enabled and fireproximityprompt then
                local id = GetUniqueID(obj)
                if IsAllowed(id) and DistanceTo(obj.Parent) <= S.Radius and Cooldown(obj, 0.1) then
                    local oh = obj.HoldDuration
                    pcall(function() obj.HoldDuration = 0 end)
                    pcall(function() fireproximityprompt(obj) end)
                    pcall(function() obj.HoldDuration = oh end)
                end

            -- ClickDetector
            elseif S.EnableClickDetector and obj:IsA("ClickDetector") and fireclickdetector then
                local id = GetUniqueID(obj)
                if IsAllowed(id) and DistanceTo(obj.Parent) <= S.Radius and Cooldown(obj, 0.15) then
                    pcall(function() fireclickdetector(obj) end)
                end

            -- Touch
            elseif S.EnableTouch and hrp and firetouchinterest and IsLikelyTouch(obj) then
                local id = GetUniqueID(obj)
                if IsAllowed(id) and DistanceTo(obj) <= S.Radius and Cooldown(obj, 0.5) then
                    pcall(function() firetouchinterest(hrp, obj, 0) end)
                    pcall(function() firetouchinterest(hrp, obj, 1) end)
                end
            end
        end
    end
end

local function StartMaster()
    if S._threads.master then return end
    S._threads.master = task.spawn(function()
        while S.MasterEnabled do
            pcall(ScanAll)
            if S.InstantMode then RunService.Heartbeat:Wait()
            else task.wait(math.max(S.InteractionDelay, 0.01)) end
        end
        S._threads.master = nil
    end)
end

-- Quét interactables để show UI whitelist (kèm object info)
local function ScanInteractables()
    S.ScannedInteract = {}
    local r = math.max(S.Radius * 2, 100)
    local seen = {}

    for _, obj in ipairs(Workspace:GetDescendants()) do
        local entry
        if obj:IsA("ProximityPrompt") then
            entry = {
                inst = obj, kind = "Proximity",
                name = obj.ObjectText ~= "" and obj.ObjectText
                    or (obj.Parent and obj.Parent.Name or "Prompt"),
                action = obj.ActionText ~= "" and obj.ActionText or "Tương tác",
            }
        elseif obj:IsA("ClickDetector") then
            entry = {
                inst = obj, kind = "Click",
                name = obj.Parent and obj.Parent.Name or "ClickDetector",
                action = "Click",
            }
        elseif IsLikelyTouch(obj) and DistanceTo(obj) <= r then
            entry = { inst = obj, kind = "Touch", name = obj.Name, action = "Chạm" }
        end

        if entry then
            local id = GetUniqueID(obj)
            if not seen[id] then
                seen[id] = true
                entry.id = id
                entry.distance = math.floor(DistanceTo(
                    obj:IsA("BasePart") and obj or obj.Parent
                ))
                if entry.distance <= r then
                    table.insert(S.ScannedInteract, entry)
                end
            end
        end
    end

    table.sort(S.ScannedInteract, function(a, b) return a.distance < b.distance end)
end

--==================================================================--
-- [PHẦN 7] HUD SCANNER NÂNG CẤP                                     --
--==================================================================--
local HUD = {}

function HUD.Scan()
    S.HUDList = {}
    for _, sg in ipairs(PlayerGui:GetChildren()) do
        if sg:IsA("ScreenGui") and sg.Enabled
            and sg.Name ~= "_SUNNY_FAB" and sg.Name ~= "Rayfield" then
            for _, d in ipairs(sg:GetDescendants()) do
                local valid = (d:IsA("TextButton") or d:IsA("ImageButton")
                    or d:IsA("TextLabel") or d:IsA("ImageLabel") or d:IsA("Frame"))
                if valid and IsTrulyVisible(d) then
                    local txt = ""
                    if d:IsA("TextButton") or d:IsA("TextLabel") then txt = d.Text or "" end
                    table.insert(S.HUDList, {
                        inst = d, name = d.Name, text = txt,
                        class = d.ClassName, parent = sg.Name,
                        id = GetUniqueID(d),
                    })
                end
            end
        end
    end
    -- Sort: Button trước, có Text trước
    table.sort(S.HUDList, function(a, b)
        local pa = (a.class == "TextButton" or a.class == "ImageButton") and 2 or (a.text ~= "" and 1 or 0)
        local pb = (b.class == "TextButton" or b.class == "ImageButton") and 2 or (b.text ~= "" and 1 or 0)
        return pa > pb
    end)
end

-- Loop xử lý HUD targets - dùng đa luồng
local function StartHUDLoop()
    if S._threads.hud then return end
    S._threads.hud = task.spawn(function()
        while S.HUDMasterEnabled do
            for guiObj, action in pairs(S.HUDTargets) do
                pcall(function()
                    if not guiObj or not guiObj.Parent then
                        S.HUDTargets[guiObj] = nil
                        return
                    end

                    if action == "click" and IsTrulyVisible(guiObj) and Cooldown(guiObj, 0.1) then
                        local pos, sz = guiObj.AbsolutePosition, guiObj.AbsoluteSize
                        FireUIClick(pos.X + sz.X/2, pos.Y + sz.Y/2)
                    elseif action == "hide" and Cooldown(guiObj, 0.3) then
                        pcall(function() guiObj.Visible = false end)
                    elseif action == "destroy" and Cooldown(guiObj, 1) then
                        pcall(function() guiObj:Destroy() end)
                        S.HUDTargets[guiObj] = nil
                    end
                end)
            end
            task.wait(0.03)  -- Loop nhanh hơn (~30fps) cho phản hồi tức thì
        end
        S._threads.hud = nil
    end)
end

-- Thao tác bulk: áp 1 action cho TẤT CẢ HUD trong list
function HUD.ApplyAll(action)
    for _, h in ipairs(S.HUDList) do
        S.HUDTargets[h.inst] = action
    end
end

function HUD.ClearAll()
    S.HUDTargets = {}
end

--==================================================================--
-- [PHẦN 8] NHÂN BẢN VẬT PHẨM - 3 PHƯƠNG THỨC                        --
--==================================================================--
-- 1. LOCAL DEEP CLONE: clone client-side (hiển thị + test)
-- 2. REMOTE REPLAY: phát lại remote pickup đã capture (server-side nhân bản)
-- 3. SERVER FORCE PARENT: thử move item từ storage → backpack (game-dependent)

local Cloner = {}

local function EnsureStorage()
    local f = Workspace:FindFirstChild("_SUNNY_STORAGE")
    if not f then
        f = Instance.new("Folder")
        f.Name = "_SUNNY_STORAGE"
        f.Parent = Workspace
    end
    return f
end

-- Bật Archivable đệ quy (cần để clone)
local function ForceArchivable(inst)
    pcall(function() inst.Archivable = true end)
    for _, c in ipairs(inst:GetDescendants()) do
        pcall(function() c.Archivable = true end)
    end
end

-- PHƯƠNG THỨC 1: Local Deep Clone (giữ Properties + Scripts)
function Cloner.LocalClone(inst, dest)
    if not inst then return nil, "Không có instance" end
    ForceArchivable(inst)
    local ok, c = pcall(function() return inst:Clone() end)
    if not ok or not c then return nil, "Clone thất bại" end

    for _, ch in ipairs(c:GetDescendants()) do
        if ch:IsA("LocalScript") or ch:IsA("Script") then
            pcall(function() ch.Disabled = false end)
        end
    end

    c.Parent = dest or EnsureStorage()
    return c
end

-- PHƯƠNG THỨC 2: Replay remote pickup đã capture
-- User capture remote khi nhặt 1 item → script replay N lần để nhận N item
function Cloner.ReplayPickup(times, delay)
    local cap = S.CapturedPickupRemote
    if not cap or not cap.instance or not cap.instance.Parent then
        return false, "Chưa capture remote nhặt nào. Bật Spy ở tab Spy → nhặt 1 item → Capture"
    end
    times = math.clamp(times or 1, 1, 100)
    delay = math.max(delay or 0.1, 0.01)

    task.spawn(function()
        for i = 1, times do
            pcall(function()
                if cap.method == "FireServer" then
                    cap.instance:FireServer(table.unpack(cap.args))
                else
                    cap.instance:InvokeServer(table.unpack(cap.args))
                end
            end)
            if i < times then task.wait(delay) end
        end
    end)
    return true, ("Đã phát lại %d lần"):format(times)
end

-- PHƯƠNG THỨC 3: Force parent (thử move item từ Storage → Backpack)
function Cloner.ForceParentToBackpack(inst)
    if not inst then return false, "Không có instance" end
    if not (inst:IsA("Tool") or inst:IsA("HopperBin")) then
        return false, "Chỉ áp dụng cho Tool/HopperBin"
    end
    local bp = LP:FindFirstChild("Backpack")
    if not bp then return false, "Không có Backpack" end

    -- Clone trước, đặt vào backpack
    local c, err = Cloner.LocalClone(inst, bp)
    if not c then return false, err end
    return true, "Đã đẩy clone vào Backpack (server có thể từ chối)"
end

-- Hook __namecall để capture remote pickup
local oldNamecall
local function InstallSpy()
    if S.SpyHookInstalled then return true end
    if not hookmetamethod then
        warn("[SPY] Executor không hỗ trợ hookmetamethod")
        return false
    end
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod and getnamecallmethod() or ""
        if S.SpyEnabled and (method == "FireServer" or method == "InvokeServer") then
            pcall(function()
                if self:IsA("RemoteEvent") or self:IsA("RemoteFunction") then
                    local args = {...}
                    table.insert(S.LastSpyLog, 1, {
                        time = os.date("%H:%M:%S"),
                        name = self.Name, method = method,
                        args = args, remote = self,
                    })
                    if #S.LastSpyLog > 30 then table.remove(S.LastSpyLog) end
                end
            end)
        end
        return oldNamecall(self, ...)
    end)
    S.SpyHookInstalled = true
    return true
end

local function ScanBag()
    S.BagItems = {}
    local bp = LP:FindFirstChild("Backpack")
    local ch = LP.Character
    if bp then
        for _, i in ipairs(bp:GetChildren()) do
            if i:IsA("Tool") or i:IsA("HopperBin") then
                table.insert(S.BagItems, {
                    name = i.Name, inst = i, loc = "Túi", equipped = false,
                    id = GetUniqueID(i),
                })
            end
        end
    end
    if ch then
        for _, i in ipairs(ch:GetChildren()) do
            if i:IsA("Tool") or i:IsA("HopperBin") then
                table.insert(S.BagItems, {
                    name = i.Name .. " [đang cầm]", inst = i, loc = "Tay",
                    equipped = true, id = GetUniqueID(i),
                })
            end
        end
    end
end

local function ResolvePath(s)
    local segs = {}
    for w in s:gmatch("[^%.]+") do table.insert(segs, w) end
    if #segs == 0 then return nil end
    local root
    if segs[1] == "ReplicatedStorage" then root = RS
    elseif segs[1] == "PlayerGui" then root = PlayerGui
    elseif segs[1] == "Workspace" then root = workspace
    else pcall(function() root = game:GetService(segs[1]) end) end
    if not root then return nil end
    local cur = root
    for i = 2, #segs do
        cur = cur:FindFirstChild(segs[i])
        if not cur then return nil end
    end
    return cur
end

local function ScanStorageItems()
    S.StorageItems = {}
    for _, path in ipairs(S.StoragePaths) do
        local c = ResolvePath(path)
        if c then
            for _, d in ipairs(c:GetDescendants()) do
                if d:IsA("Tool") or d:IsA("HopperBin")
                    or (d:IsA("Model") and d.PrimaryPart) then
                    table.insert(S.StorageItems, {
                        name = d.Name, inst = d, loc = path,
                        class = d.ClassName, id = GetUniqueID(d),
                    })
                end
            end
        end
    end
end

--==================================================================--
-- [PHẦN 9] KÉO VẬT PHẨM - FIX RESPAWN + AUTO DRAG                   --
--==================================================================--
local Drag = {}

-- Tạo drag setup giữa HRP và part bất kỳ
function Drag.AttachTo(part)
    Drag.Release()
    if not part or not part:IsA("BasePart") then return false, "Object không hợp lệ" end
    if part.Anchored then return false, "Object đang Anchored - không kéo được" end

    local hrp = GetHRP()
    if not hrp then return false, "Không có HumanoidRootPart" end

    local hrpAtt = Instance.new("Attachment")
    hrpAtt.Name = "_SUNNY_HRPAtt"
    hrpAtt.Parent = hrp

    local partAtt = Instance.new("Attachment")
    partAtt.Name = "_SUNNY_PartAtt"
    partAtt.Parent = part

    local align = Instance.new("AlignPosition")
    align.Attachment0 = partAtt
    align.Attachment1 = hrpAtt
    align.MaxForce = 100000
    align.Responsiveness = 30
    align.RigidityEnabled = false
    align.Parent = part

    _G.SUNNY.DragTarget = part
    _G.SUNNY.DragHRPAtt = hrpAtt
    _G.SUNNY.DragPartAtt = partAtt
    _G.SUNNY.DragAlign = align
    S.DragTarget = part

    -- Chỉ start update thread 1 lần duy nhất
    if not S._threads.drag then
        S._threads.drag = task.spawn(function()
            while _G.SUNNY.DragTarget do
                local target = _G.SUNNY.DragTarget
                local att = _G.SUNNY.DragHRPAtt
                if not target or not target.Parent then
                    _G.SUNNY.DragTarget = nil
                    break
                end

                local hrp2 = GetHRP()
                if hrp2 and att and att.Parent then
                    if S.DragMode == "Back" then
                        att.CFrame = CFrame.new(0, 0, S.DragDistance)  -- sau lưng (Z+)
                    elseif S.DragMode == "Front" then
                        att.CFrame = CFrame.new(0, 0, -S.DragDistance) -- trước mặt (Z-)
                    elseif S.DragMode == "Top" then
                        att.CFrame = CFrame.new(0, S.DragDistance, 0)
                    elseif S.DragMode == "Right" then
                        att.CFrame = CFrame.new(S.DragDistance, 0, 0)
                    elseif S.DragMode == "Crosshair" then
                        local cam = workspace.CurrentCamera
                        if cam then
                            local dir = cam.CFrame.LookVector
                            att.WorldCFrame = CFrame.new(hrp2.Position + dir * S.DragDistance)
                        end
                    end
                elseif att and not att.Parent then
                    -- HRP att đã bị mất (respawn) → tự tái tạo nếu vẫn còn target
                    if _G.SUNNY.DragTarget and _G.SUNNY.DragTarget.Parent then
                        local oldTarget = _G.SUNNY.DragTarget
                        task.wait(1)  -- Đợi character load lại
                        Drag.AttachTo(oldTarget)
                        break
                    end
                end
                RunService.Heartbeat:Wait()
            end
            S._threads.drag = nil
        end)
    end

    return true
end

function Drag.Release()
    if _G.SUNNY.DragAlign then pcall(function() _G.SUNNY.DragAlign:Destroy() end) end
    if _G.SUNNY.DragHRPAtt then pcall(function() _G.SUNNY.DragHRPAtt:Destroy() end) end
    if _G.SUNNY.DragPartAtt then pcall(function() _G.SUNNY.DragPartAtt:Destroy() end) end
    _G.SUNNY.DragAlign = nil
    _G.SUNNY.DragHRPAtt = nil
    _G.SUNNY.DragPartAtt = nil
    _G.SUNNY.DragTarget = nil
    S.DragTarget = nil
end

-- Tìm BasePart unanchored gần nhất trong radius
function Drag.FindNearest()
    local hrp = GetHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj.Anchored and obj.Name ~= "Handle" then
            local m = obj:FindFirstAncestorOfClass("Model")
            local hasHum = m and m:FindFirstChildOfClass("Humanoid")
            if not hasHum and obj ~= _G.SUNNY.DragTarget then
                -- Bỏ qua part nhỏ xíu (effect particles...)
                if obj.Size.Magnitude > 0.5 then
                    local d = (hrp.Position - obj.Position).Magnitude
                    if d < bestDist and d <= S.Radius then
                        best, bestDist = obj, d
                    end
                end
            end
        end
    end
    return best
end

function Drag.GrabNearest()
    local p = Drag.FindNearest()
    if not p then return false, "Không tìm thấy object phù hợp" end
    return Drag.AttachTo(p)
end

-- Auto-drag loop: tự grab object gần nhất khi không có target
local function StartAutoDrag()
    if S._threads.autodrag then return end
    S._threads.autodrag = task.spawn(function()
        while S.AutoDragEnabled do
            -- Nếu chưa grab gì → tìm và grab
            if not _G.SUNNY.DragTarget or not _G.SUNNY.DragTarget.Parent then
                pcall(Drag.GrabNearest)
            end
            task.wait(0.5)
        end
        S._threads.autodrag = nil
    end)
end

