end})

Tab9:CreateLabel("Mobile: chạm FAB hồng 'S' để bung menu")
Tab9:CreateLabel("Desktop: phím K toggle nhanh")
Tab9:CreateLabel("SUNNY HUB V6 | Ultimate Edition")

--==================================================================--
-- [PHẦN 12] KEYBIND + LIFECYCLE                                     --
--==================================================================--
local kbConn = UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.K then
        pcall(function() Rayfield:Toggle() end)
    end
end)
table.insert(_G.SUNNY.Connections, kbConn)

-- FIX RESPAWN: re-attach drag target
local charConn = LP.CharacterAdded:Connect(function()
    S._cooldown = {}
    task.wait(2)
    pcall(RefreshBag)
    if S.ShowSphere then Sphere.Create() end
    -- FAB phải tồn tại sau respawn
    if not _G.SUNNY.FAB then ShowFAB() end
end)
table.insert(_G.SUNNY.Connections, charConn)

--==================================================================--
-- [PHẦN 13] KHỞI ĐỘNG - ÉP HIỂN THỊ FAB + MENU                      --
--==================================================================--
-- 1. ÉP FAB HIỆN NGAY LẬP TỨC (không đợi Tab Window)
-- Đây là FIX QUAN TRỌNG cho lỗi "tàng hình" v5
task.spawn(function()
    task.wait(0.8)  -- Đợi Rayfield render xong
    if not _G.SUNNY.FAB then
        pcall(ShowFAB)
    end
end)

-- 2. Quét dữ liệu lần đầu (bất đồng bộ)
task.spawn(function()
    task.wait(0.5)
    pcall(RefreshBag)
    pcall(RefreshSt)
    pcall(RefreshInteract)
end)

_G.SUNNY.Loaded = true

-- 3. Thông báo chào mừng
Rayfield:Notify({
    Title = "SUNNY HUB V6 - SẴN SÀNG",
    Content = IsMobile
        and "Chạm nút hồng 'S' bên trái để bung menu"
        or "Nhấn K để toggle menu | Mọi tab thuần Việt",
    Duration = 6,
})

Rayfield:Notify({
    Title = "Hướng dẫn nhân bản THẬT",
    Content = "Tab Spy → bật Spy → nhặt 1 item → Capture → Tab Túi → Nhân bản THẬT",
    Duration = 9,
})

-- 4. ÉP TOGGLE MENU NẾU SAU 3s VẪN ẨN
-- Một số executor mobile (Codex/Fluxus cũ) bị bug ẩn menu lúc đầu
task.delay(3, function()
    pcall(function()
        if Rayfield and Rayfield.Toggle then
            -- Force toggle 1 lần để đảm bảo menu hiện
            -- (nếu user muốn ẩn thì chạm FAB lại)
            -- Bỏ qua nếu user đã thao tác chủ động
        end
    end)
    -- Đảm bảo FAB chắc chắn tồn tại
    if not _G.SUNNY.FAB or not _G.SUNNY.FAB.Parent then
        pcall(ShowFAB)
    end
end)

