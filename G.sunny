local Tab4 = Window:CreateTab("Quét HUD", "scan-eye")

Tab4:CreateSection("Quét và điều khiển HUD/GUI trên màn hình")

local hudPara = Tab4:CreateParagraph({Title="HUD: 0", Content="Nhấn 'Quét HUD'"})
local hudInfoPara = Tab4:CreateParagraph({
    Title = "Thông tin HUD đã chọn",
    Content = "Chọn 1 HUD từ dropdown"
})

local hudDD

local function GetHUDOpts()
    local o = {}
    for i, h in ipairs(S.HUDList) do
        local mark = S.HUDTargets[h.inst]
        local prefix = ""
        if mark == "click" then prefix = "[AN] "
        elseif mark == "hide" then prefix = "[AN-DI] "
        elseif mark == "destroy" then prefix = "[XOA] " end

        local label = h.text ~= "" and h.text or h.name
        if #label > 25 then label = label:sub(1,22).."..." end
        table.insert(o, ("%d. %s%s [%s]"):format(i, prefix, label, h.class))
        if i >= 80 then break end
    end
    if #o == 0 then table.insert(o, "(trống)") end
    return o
end

local function RefreshHUD()
    HUD.Scan()
    local txt = ""
    for i, h in ipairs(S.HUDList) do
        local label = h.text ~= "" and h.text or h.name
        if #label > 22 then label = label:sub(1,19).."..." end
        local mark = S.HUDTargets[h.inst]
        local prefix = ""
        if mark == "click" then prefix = "[AN] "
        elseif mark == "hide" then prefix = "[AD] "
        elseif mark == "destroy" then prefix = "[XO] " end
        txt = txt .. ("%s%d. %s\n"):format(prefix, i, label)
        if i >= 18 then
            txt = txt .. ("... +%d"):format(#S.HUDList - 18); break
        end
    end
    if txt == "" then txt = "Không có HUD nào" end
    hudPara:Set({Title=("HUD: %d"):format(#S.HUDList), Content=txt})
    if hudDD then hudDD:Refresh(GetHUDOpts()) end
end

Tab4:CreateButton({Name="Quét HUD", Callback=RefreshHUD})

